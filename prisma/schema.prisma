generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPPORT
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model User {
  id String @id @default(uuid())

  name String @map("name")

  email String @unique @map("email")

  phone String @unique @map("phone")

  role UserRole @default(USER) @map("role")

  status UserStatus @default(ACTIVE) @map("status")

  isEmailVerified Boolean @default(false) @map("is_email_verified")

  isPhoneVerified Boolean @default(false) @map("is_phone_verified")

  lastLoginAt DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  isDeleted Boolean @default(false) @map("is_deleted")

  sessions UserSession[]

  @@map("users")
}

model UserSession {
  id String @id @default(uuid())

  userId String @map("user_id")

  refreshTokenHash String @map("refresh_token_hash")

  deviceInfo String? @map("device_info")

  ipAddress String? @map("ip_address")

  userAgent String? @map("user_agent")

  expiresAt DateTime @map("expires_at")

  lastUsedAt DateTime? @map("last_used_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model AppConfig {
  id String @id @default(uuid()) @map("id")

  key String @unique @map("key")

  value String @map("value")

  description String? @map("description")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_configs")
}

model Merchant {
  id String @id @default(uuid()) @map("id")

  name String @unique @map("name")

  slug String @unique @map("slug")

  description String? @map("description")

  websiteUrl String? @map("website_url")

  logoUrl String? @map("logo_url")

  logoPublicId String? @map("logo_public_id")

  bannerUrl String? @map("banner_url")

  cashbackText String? @map("cashback_text")

  cashback Float? @map("cashback")

  termsAndConditions String? @map("terms_and_conditions")

  trackingSettings Json? @map("tracking_settings")

  isFeatured Boolean @default(false) @map("is_featured")

  isActive Boolean @default(true) @map("is_active")

  isDeleted Boolean @default(false) @map("is_deleted")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  productSources ProductSource[]

  @@index([slug])
  @@index([isActive])
  @@map("merchants")
}

model Banner {
  id            String   @id @default(uuid()) @map("id")
  title         String   @map("title")
  description   String?  @map("description")
  imageUrl      String   @map("image_url")
  imagePublicId String?  @map("image_public_id")
  tags          String[] @default([]) @map("tags")
  offerTitle    String?  @map("offer_title")
  link          String?  @map("link")
  placement     String   @default("HERO") @map("placement")
  order         Int      @default(0) @map("order")
  isActive      Boolean  @default(true) @map("is_active")
  isDeleted     Boolean  @default(false) @map("is_deleted")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("banners")
}

model Product {
  id                 String                 @id @default(uuid()) @map("id")
  name               String                 @map("name")
  description        String                 @map("description")
  imageUrls          String[]               @map("image_urls")
  imagePublicIds     String[]               @map("image_public_ids")
  price              Float                  @map("price")
  isActive           Boolean                @default(true) @map("is_active")
  isFeatured         Boolean                @default(false) @map("is_featured")
  
  // Cashback Info
  cashbackPercentage Float                  @map("cashback_percentage")
  cashbackTerms      String                 @map("cashback_terms")

  // Payment Timeline Info
  trackingTime       Int                    @map("tracking_time")
  validationTime     Int                    @map("validation_time")
  paymentRelease     Int                    @map("payment_release")

  isDeleted          Boolean                @default(false) @map("is_deleted")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  categories         ProductCategory[]
  productSources     ProductSource[]

  @@index([price])
  @@index([isActive, isDeleted])
  @@map("products")
}

model Category {
  id        String            @id @default(uuid()) @map("id")
  name      String            @unique @map("name")
  slug      String            @unique @map("slug")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  products  ProductCategory[]

  @@map("categories")
}

model ProductCategory {
  productId  String   @map("product_id")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
  @@map("product_categories")
}

enum ConversionStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CashbackStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LedgerType {
  CREDIT
  DEBIT
}

model AffiliateLink {
  id                String   @id @default(uuid()) @map("id")
  entityType        String   @map("entity_type") // MERCHANT, PRODUCT_SOURCE, CATEGORY, BANNER, CAMPAIGN, OFFER, REFERRAL
  entityId          String   @map("entity_id")
  merchantId        String?  @map("merchant_id")
  originalUrl       String   @map("original_url")
  affiliateUrl      String   @map("affiliate_url")
  cashbackPercent   Float    @map("cashback_percent")
  commissionPercent Float?   @map("commission_percent")
  priority          Int      @default(0) @map("priority")
  isActive          Boolean  @default(true) @map("is_active")
  createdBy         String?  @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  clicks            Click[]

  @@index([entityType, entityId])
  @@map("affiliate_links")
}

model Click {
  id              String           @id @default(uuid()) @map("id")
  clickId         String           @unique @map("click_id")
  userId          String           @map("user_id")
  entityType      String           @map("entity_type") // MERCHANT, PRODUCT_SOURCE, CATEGORY, BANNER, CAMPAIGN, OFFER, REFERRAL
  entityId        String           @map("entity_id")
  merchantId      String?          @map("merchant_id")
  productSourceId String?          @map("product_source_id")
  affiliateLinkId String?          @map("affiliate_link_id")
  campaignId      String?          @map("campaign_id")
  referralId      String?          @map("referral_id")
  ip              String?          @map("ip")
  browser         String?          @map("browser")
  device          String?          @map("device")
  status          String           @default("ACTIVE") @map("status") // ACTIVE, CONVERTED, FRAUD
  createdAt       DateTime         @default(now()) @map("created_at")

  affiliateLink   AffiliateLink?   @relation(fields: [affiliateLinkId], references: [id], onDelete: SetNull)
  conversions     Conversion[]
  fraudFlags      FraudFlag[]

  @@index([userId])
  @@index([clickId])
  @@map("clicks")
}

model Conversion {
  id               String           @id @default(uuid()) @map("id")
  clickId          String?          @map("click_id")
  transactionId    String           @unique @map("transaction_id")
  orderAmount      Float            @map("order_amount")
  commissionAmount Float            @map("commission_amount")
  cashbackAmount   Float            @map("cashback_amount")
  status           ConversionStatus @default(PENDING) @map("status")
  conversionDate   DateTime         @default(now()) @map("conversion_date")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  click            Click?           @relation(fields: [clickId], references: [clickId], onDelete: SetNull)
  cashbacks        Cashback[]

  @@index([clickId])
  @@index([transactionId])
  @@map("conversions")
}

model Cashback {
  id                     String         @id @default(uuid()) @map("id")
  userId                 String         @map("user_id")
  conversionId           String?        @map("conversion_id")
  amount                 Float          @map("amount")
  status                 CashbackStatus @default(PENDING) @map("status")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  conversion             Conversion?    @relation(fields: [conversionId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([conversionId])
  @@map("cashbacks")
}

model Wallet {
  id        String         @id @default(uuid()) @map("id")
  userId    String         @unique @map("user_id")
  balance   Float          @default(0.0) @map("balance")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  ledger    WalletLedger[]

  @@map("wallets")
}

model WalletLedger {
  id          String     @id @default(uuid()) @map("id")
  walletId    String     @map("wallet_id")
  amount      Float      @map("amount") // Positive for credit, negative for debit
  type        LedgerType @map("type")
  description String?    @map("description")
  referenceId String?    @map("reference_id") // E.g., cashbackId or withdrawalId
  createdAt   DateTime   @default(now()) @map("created_at")

  wallet      Wallet     @relation(fields: [walletId], references: [id], onDelete: Restrict)

  @@index([walletId])
  @@map("wallet_ledgers")
}

model FraudFlag {
  id          String   @id @default(uuid()) @map("id")
  clickId     String?  @map("click_id")
  userId      String?  @map("user_id")
  ipAddress   String?  @map("ip_address")
  reason      String   @map("reason")
  severity    String   @map("severity")
  createdAt   DateTime @default(now()) @map("created_at")

  click       Click?   @relation(fields: [clickId], references: [clickId], onDelete: Cascade)

  @@map("fraud_flags")
}

model ProductSource {
  id                 String   @id @default(uuid()) @map("id")
  productId          String   @map("product_id")
  merchantId         String   @map("merchant_id")
  originalProductUrl String   @map("original_product_url")
  currentPrice       Float    @default(0.0) @map("current_price")
  stock              Int      @default(0) @map("stock")
  status             String   @default("ACTIVE") @map("status")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  merchant           Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([merchantId])
  @@map("product_sources")
}

model ClickAnalytics {
  id              String   @id @default(uuid()) @map("id")
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id")
  merchantId      String?  @map("merchant_id")
  productSourceId String?  @map("product_source_id")
  device          String?  @map("device")
  browser         String?  @map("browser")
  ip              String?  @map("ip")
  country         String?  @map("country")
  referrer        String?  @map("referrer")
  clickedAt       DateTime @default(now()) @map("clicked_at")

  @@index([entityType, entityId])
  @@map("click_analytics")
}