generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPPORT
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model User {
  id String @id @default(uuid())

  name String @map("name")

  email String @unique @map("email")

  phone String @unique @map("phone")

  role UserRole @default(USER) @map("role")

  status UserStatus @default(ACTIVE) @map("status")

  isEmailVerified Boolean @default(false) @map("is_email_verified")

  isPhoneVerified Boolean @default(false) @map("is_phone_verified")

  lastLoginAt DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  isDeleted Boolean @default(false) @map("is_deleted")

  sessions UserSession[]

  @@map("users")
}

model UserSession {
  id String @id @default(uuid())

  userId String @map("user_id")

  refreshTokenHash String @map("refresh_token_hash")

  deviceInfo String? @map("device_info")

  ipAddress String? @map("ip_address")

  userAgent String? @map("user_agent")

  expiresAt DateTime @map("expires_at")

  lastUsedAt DateTime? @map("last_used_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model AppConfig {
  id String @id @default(uuid()) @map("id")

  key String @unique @map("key")

  value String @map("value")

  description String? @map("description")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_configs")
}

model Merchant {
  id String @id @default(uuid()) @map("id")

  name String @unique @map("name")

  slug String @unique @map("slug")

  description String? @map("description")

  websiteUrl String? @map("website_url")

  affiliateUrl String? @map("affiliate_url")

  logoUrl String? @map("logo_url")

  logoPublicId String? @map("logo_public_id")

  bannerUrl String? @map("banner_url")

  cashbackText String? @map("cashback_text")

  termsAndConditions String? @map("terms_and_conditions")

  isFeatured Boolean @default(false) @map("is_featured")

  isActive Boolean @default(true) @map("is_active")

  isDeleted Boolean @default(false) @map("is_deleted")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([isActive])
  @@map("merchants")
}

model Banner {
  id            String   @id @default(uuid()) @map("id")
  title         String   @map("title")
  description   String?  @map("description")
  imageUrl      String   @map("image_url")
  imagePublicId String?  @map("image_public_id")
  tags          String[] @default([]) @map("tags")
  offerTitle    String?  @map("offer_title")
  link          String?  @map("link")
  placement     String   @default("HERO") @map("placement")
  order         Int      @default(0) @map("order")
  isActive      Boolean  @default(true) @map("is_active")
  isDeleted     Boolean  @default(false) @map("is_deleted")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("banners")
}

model Product {
  id                 String                 @id @default(uuid()) @map("id")
  name               String                 @map("name")
  description        String                 @map("description")
  imageUrls          String[]               @map("image_urls")
  imagePublicIds     String[]               @map("image_public_ids")
  price              Float                  @map("price")
  isActive           Boolean                @default(true) @map("is_active")
  isFeatured         Boolean                @default(false) @map("is_featured")
  
  // Cashback Info
  cashbackPercentage Float                  @map("cashback_percentage")
  cashbackTerms      String                 @map("cashback_terms")

  // Payment Timeline Info
  trackingTime       Int                    @map("tracking_time")
  validationTime     Int                    @map("validation_time")
  paymentRelease     Int                    @map("payment_release")

  isDeleted          Boolean                @default(false) @map("is_deleted")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  affiliateLinks     ProductAffiliateLink[]
  categories         ProductCategory[]

  @@index([price])
  @@index([isActive, isDeleted])
  @@map("products")
}

model Category {
  id        String            @id @default(uuid()) @map("id")
  name      String            @unique @map("name")
  slug      String            @unique @map("slug")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  products  ProductCategory[]

  @@map("categories")
}

model ProductCategory {
  productId  String   @map("product_id")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
  @@map("product_categories")
}

model ProductAffiliateLink {
  id                 String   @id @default(uuid()) @map("id")
  productId          String   @map("product_id")
  platformName       String   @map("platform_name")
  affiliateLink      String   @map("affiliate_link")
  mrp                Float    @map("mrp")
  sellPrice          Float    @map("sell_price")
  cashbackPercentage Float    @map("cashback_percentage")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_affiliate_links")
}